enum GeneralImageType {
  product_detail_info // 상세페이지
  event // 이벤트
  product // 상품
}

// 다국어 설정 (기준/공용/사용 언어)
model GeneralInfo {
  id              Int      @id @default(autoincrement())
  useLanguage     Json     @default("{\"ja\": false, \"ko\": false, \"en\": false, \"zhCN\": false, \"zhTW\": false, \"vi\": false, \"th\": false, \"ru\": false}") @map("use_language") // 사용 언어
  defaultLanguage String   @map("default_language") @db.VarChar(10) // 기준 언어
  publicLanguage  String   @map("public_language") @db.VarChar(10) // 공용 언어
  createdAt       DateTime @default(now()) @map("created_at") // 생성일시
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") // 수정일시

  @@map("general_info")
}

model GeneralImageCategory {
  id        Int               @id @default(autoincrement())
  name      String            @db.VarChar(50)
  type      GeneralImageType? @map("type")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime?         @map("deleted_at")

  generalImages GeneralImage[]

  @@map("general_image_category")
}

model GeneralImage {
  code            String    @id @default(dbgenerated("generate_custom_id('IMG')")) @map("code")
  imageCategoryId Int       @map("image_category_id")
  name            String    @db.VarChar(50)
  path            String    @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  imageCategory                  GeneralImageCategory         @relation(fields: [imageCategoryId], references: [id], onDelete: Cascade)
  productTranslations            ProductTranslation[]
  productCategoryTranslations    ProductCategoryTranslation[]
  productDetailInfoTranslations  ProductDetailInfoTranslation[]

  @@map("general_image")
}
