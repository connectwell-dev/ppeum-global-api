model PopupBasic {
  id          Int       @id @default(autoincrement())
  useLanguage Json      @default("{\"ja\": false, \"ko\": false, \"en\": false, \"zhCn\": false, \"zhTw\": false, \"vi\": false, \"th\": false, \"ru\": false}") @map("use_language") // 사용 언어
  startAt     String    @map("start_at") // 시작일
  startTime   String    @map("start_time") // 시작시간
  endAt       String    @map("end_at") // 종료일
  endTime     String    @map("end_time") // 종료시간
  createdAt   DateTime  @default(now()) @map("created_at") // 생성일시
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") // 수정일시
  deletedAt   DateTime? @map("deleted_at") // 삭제일시

  images PopupBasicImage[]

  @@map("popup_basic")
}

model PopupMain {
  id          Int       @id @default(autoincrement())
  useLanguage Json      @default("{\"ja\": false, \"ko\": false, \"en\": false, \"zhCn\": false, \"zhTw\": false, \"vi\": false, \"th\": false, \"ru\": false}") @map("use_language") // 사용 언어
  createdAt   DateTime  @default(now()) @map("created_at") // 생성일시
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") // 수정일시
  deletedAt   DateTime? @map("deleted_at") // 삭제일시

  images PopupMainImage[]

  @@map("popup_main")
}

model PopupMainImage {
  id          Int       @id @default(autoincrement())
  popupMainId Int       @map("popup_main_id")
  order       Int       @default(1) @map("order")
  path        String    @db.VarChar(255) // 이미지 path
  title       String    @db.VarChar(100) // 타이틀
  link        String?   @db.VarChar(500) // 링크
  isNewTab    Boolean   @default(false) @map("is_new_tab") // 새창여부
  startAt     String    @map("start_at") // 시작일
  startTime   String    @map("start_time") // 시작시간
  endAt       String    @map("end_at") // 종료일
  endTime     String    @map("end_time") // 종료시간
  createdAt   DateTime  @default(now()) @map("created_at") // 생성일시
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") // 수정일시
  deletedAt   DateTime? @map("deleted_at") // 삭제일시

  popupMain PopupMain @relation(fields: [popupMainId], references: [id], onDelete: Cascade)

  @@map("popup_main_image")
}

model PopupBasicImage {
  id           Int        @id @default(autoincrement())
  popupBasicId Int        @map("popup_basic_id")
  path         String     @db.VarChar(255) // 이미지 path
  createdAt    DateTime   @default(now()) @map("created_at") // 생성일시
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") // 수정일시
  deletedAt    DateTime?  @map("deleted_at") // 삭제일시
  popupBasic   PopupBasic @relation(fields: [popupBasicId], references: [id], onDelete: Cascade)

  @@map("popup_basic_image")
}
