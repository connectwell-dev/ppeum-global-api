// 시술설명 (상품에 매칭)
model OperationInfo {
  id          Int       @id @default(autoincrement())
  code        String    @unique @default(dbgenerated("generate_custom_id('INFO')")) @map("code") // 고유 id
  changedKeys Json[]    @default([]) @map("changed_keys") // 변경된 키 ( { key: 'name', changedAt : '2026-02-19 10:00:00' } )
  createdAt   DateTime  @default(now()) @map("created_at") // 생성일시
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") // 수정일시
  deletedAt   DateTime? @map("deleted_at") // 삭제일시

  operationInfoTranslations OperationInfoTranslation[]
  products                  Product[]

  @@map("operation_info")
}

model OperationInfoTranslation {
  operationInfoId  Int       @map("operation_info_id")
  language         Language  @default(ja) // 사용 언어
  title            String?   @db.VarChar(512) // 시술설명 타이틀
  description      String?   @db.Text // 시술설명 내용
  shortDescription Json[]    @default([]) @db.Json // 시술설명 요약
  imageCode        String?   @map("image_code") // 시술설명 이미지 code
  hashtag          String[]  @default([]) @db.Text // 시술설명 해시태그
  caution          String[]  @default([]) @db.Text // 시술설명 주의사항
  note             String?   @db.Text // 시술설명 메모
  createdAt        DateTime  @default(now()) @map("created_at") // 생성일시
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") // 수정일시
  isMatch          Boolean   @default(false) @map("is_match") // 매칭 여부
  lastChangedAt    DateTime? @default(now()) @map("last_changed_at") // 마지막 변경일시

  operationInfo OperationInfo? @relation(fields: [operationInfoId], references: [id], onDelete: Cascade)
  image         GeneralImage?  @relation(fields: [imageCode], references: [code], onDelete: SetNull)

  @@id([operationInfoId, language])
  @@index([language])
  @@map("operation_info_translation")
}
