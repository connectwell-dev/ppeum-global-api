enum ProductCategoryType {
  general // 일반
  promotion // 프로모션
}

// 상품 그룹 (엑셀 업로드 등에서 사용하는 분류 코드, 노출 카테고리와는 별개 개념)
model ProductGroup {
  id        Int      @id @default(autoincrement())
  code      String   @unique @map("code") @db.VarChar(100) // 분류코드
  name      String   @map("name") @db.VarChar(512) // 분류명
  createdAt DateTime @default(now()) @map("created_at") // 생성일시
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") // 수정일시

  @@map("product_group")
}

model Product {
  id                 Int       @id @default(autoincrement())
  code               String    @unique @default(dbgenerated("generate_custom_id('PRD')")) @map("code") // 고유 id
  isActive           Boolean   @default(true) @map("is_active") // 사용여부
  productPrice       Int       @map("product_price") // 상품 가격
  eventPrice         Int?      @map("event_price") // 이벤트가 (null이면 없음)
  startDate          String?   @map("start_date") @db.VarChar(20) // 노출 시작일
  endDate            String?   @map("end_date") @db.VarChar(20) // 노출 종료일 (null이면 상시)
  productDetailInfoId Int?     @map("product_detail_info_id") // 상세페이지 id
  changedKeys        Json[]    @default([]) @map("changed_keys")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  productTranslations      ProductTranslation[]
  productDetailInfo        ProductDetailInfo?        @relation(fields: [productDetailInfoId], references: [id], onDelete: SetNull)
  productToProductCategories ProductToProductCategory[]

  @@index([productDetailInfoId])
  @@map("product")
}

model ProductTranslation {
  productId     Int       @map("product_id")
  language      Language  @default(ja)
  name          String?   @db.VarChar(512)
  description   String?   @db.Text
  imageCode     String?   @map("image_code")
  isView        Boolean   @default(true) @map("is_view")
  isMatch       Boolean   @default(false) @map("is_match")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  lastChangedAt DateTime? @default(now()) @map("last_changed_at")

  product Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  image   GeneralImage? @relation(fields: [imageCode], references: [code], onDelete: SetNull)

  @@unique([productId, language])
  @@index([language])
  @@map("product_translation")
}

// 카테고리 (기존 이벤트)
model ProductCategory {
  id                   Int                 @id @default(autoincrement())
  code                 String              @unique @default(dbgenerated("generate_custom_id('CAT')")) @map("code")
  isActive             Boolean             @default(true) @map("is_active")
  categoryType         ProductCategoryType @default(general) @map("category_type")
  startDate            String?             @map("start_date") @db.VarChar(20)
  endDate              String?             @map("end_date") @db.VarChar(20)
  reservationStartDate String?             @map("reservation_start_date") @db.VarChar(20)
  reservationEndDate   String?             @map("reservation_end_date") @db.VarChar(20)
  weekDay              WeekDayType[]       @default([]) @map("week_day")
  changedKeys          Json[]              @default([]) @map("changed_keys")
  order                Int                 @default(0) @map("order")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @default(now()) @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  productCategoryTranslations ProductCategoryTranslation[]
  productToProductCategories  ProductToProductCategory[]

  @@index([order])
  @@map("product_category")
}

model ProductCategoryTranslation {
  productCategoryId Int
  language          Language
  name              String?   @db.VarChar(512)
  imageCode         String?   @map("image_code")
  isMatch           Boolean   @default(false) @map("is_match")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  lastChangedAt     DateTime? @default(now()) @map("last_changed_at")

  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)
  image           GeneralImage?    @relation(fields: [imageCode], references: [code], onDelete: SetNull)

  @@unique([productCategoryId, language])
  @@index([language])
  @@map("product_category_translation")
}

model ProductToProductCategory {
  productId            Int     @map("product_id")
  productCategoryId    Int     @map("product_category_id")
  eventPrice           Int     @default(0) @map("event_price")
  eventDiscountPercent Float   @default(0) @map("event_discount_percent")
  order                Int     @default(0) @map("order")
  isActive             Boolean @default(true) @map("is_active")

  product         Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id], onDelete: Cascade)

  @@id([productId, productCategoryId])
  @@map("product_to_product_category")
}
